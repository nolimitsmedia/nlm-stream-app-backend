API_PUBLIC_URL=https://192.211.56.162
SRS_API_URL=http://127.0.0.1:1985
SRS_HLS_ORIGIN=http://127.0.0.1:8080
HLS_BASE_URL=https://nlmstream.b-cdn.net/hls

DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASSWORD=replace_with_strong_password

JWT_SECRET=replace_with_long_random_secret_64_chars_minimum

RECORDINGS_ROOT=/var/nlm-srs/recordings

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_STARTER_PRICE_ID=price_replace_starter
STRIPE_ENTERPRISE_PRICE_ID=price_replace_enterprise

BUNNY_STORAGE_ZONE=your-bunny-storage-zone
BUNNY_STORAGE_HOSTNAME=ny.storage.bunnycdn.com
BUNNY_STORAGE_API_KEY=replace_with_bunny_storage_api_key
BUNNY_RECORDINGS_CDN_URL=https://your-recordings-zone.b-cdn.net

# Facebook / Meta Graph API (Go Live automation)
# Create the app at developers.facebook.com; requires App Review for
# pages_show_list, pages_read_engagement, pages_manage_posts, publish_video
# before this works for any user beyond your own Meta developer account.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://nlmstream.b-cdn.net/api/oauth/facebook/callback

# YouTube Data API (Go Live automation)
# Create OAuth credentials at console.cloud.google.com; requires Google's
# sensitive-scope verification for https://www.googleapis.com/auth/youtube
# before this works for any user beyond test users you've added.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://nlmstream.b-cdn.net/api/oauth/youtube/callback

# Super Admin Dashboard — gated server/SRS restart
# SERVER_HOSTNAME_CONFIRM: the literal text a super_admin must type to
# confirm a restart while streams are active (defaults to "bscapi54" if unset).
# SRS_DOCKER_CONTAINER: the exact SRS container name from `docker ps` --
# the restart-srs endpoint refuses to run until this is set correctly.
SERVER_HOSTNAME_CONFIRM=bscapi54
SRS_DOCKER_CONTAINER=nlm-srs
