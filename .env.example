# NLM Streaming Manager - Server Environment

NODE_ENV=production
PORT=5000

# Public URLs
CLIENT_URL=https://stream.yourdomain.com
CORS_ORIGINS=https://stream.yourdomain.com,https://www.yourdomain.com
API_PUBLIC_URL=https://api.yourdomain.com

# SRS / Streaming
SRS_API_URL=http://127.0.0.1:1985
HLS_BASE_URL=https://stream.yourdomain.com/hls

# PostgreSQL
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=streamingmanager_db
DB_USER=streamingmanager_user
DB_PASSWORD=replace_with_strong_password

# Auth
JWT_SECRET=replace_with_long_random_secret_64_chars_minimum

# Recordings
RECORDINGS_ROOT=/var/nlm-srs/recordings


# Stripe Billing
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_STARTER_PRICE_ID=price_replace_starter
STRIPE_PRO_PRICE_ID=price_replace_pro
STRIPE_ENTERPRISE_PRICE_ID=price_replace_enterprise
